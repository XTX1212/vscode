  hl(0, "DiagnosticUnderlineError", { undercurl = true, sp = "#FF5555" })

  hl(0, "DiagnosticWarn", { fg = "#D4AF37", undercurl = true, sp = "#D4AF37" })
  hl(0, "DiagnosticUnderlineWarn", { undercurl = true, sp = "#D4AF37" })

  hl(0, "DiagnosticInfo", { fg = "#8CCB5E", undercurl = true, sp = "#8CCB5E" })
  hl(0, "DiagnosticUnderlineInfo", { undercurl = true, sp = "#8CCB5E" })

  hl(0, "DiagnosticHint", { fg = "#9A9A9A", undercurl = true, sp = "#9A9A9A" })
  hl(0, "DiagnosticUnderlineHint", { undercurl = true, sp = "#9A9A9A" })

  hl(0, "DiagnosticVirtualTextError", { link = "DiagnosticError" })
  hl(0, "DiagnosticVirtualTextWarn", { link = "DiagnosticWarn" })
  hl(0, "DiagnosticVirtualTextInfo", { link = "DiagnosticInfo" })
  hl(0, "DiagnosticVirtualTextHint", { link = "DiagnosticHint" })
