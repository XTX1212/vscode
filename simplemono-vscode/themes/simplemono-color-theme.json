  hl(0, "@preproc.c", { fg = palette.macro })
  hl(0, "@define.c", { fg = palette.macro })
  hl(0, "@include.c", { fg = palette.macro })
  hl(0, "@keyword.directive.cpp", { fg = palette.macro })
  hl(0, "@constant.macro.cpp", { fg = palette.macro })
  hl(0, "@macro.cpp", { fg = palette.macro })
  hl(0, "@preproc.cpp", { fg = palette.macro })
