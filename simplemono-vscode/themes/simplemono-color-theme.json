local M = {}

function M.apply()
  vim.o.background = "dark"
  vim.o.termguicolors = true

  local palette = {
    bg = "#000000",
    fg = "#E6E6E6",
    keyword = "#D4AF37",
    string = "#8CCB5E",
    comment = "#A57C4C",
    macro = "#9A9A9A",
    dim = "#808080",
    ui_fg = "#E6E6E6",
    border = "#303030",
    line_nr = "#666666",
    git_added = "#8CCB5E",
    git_modified = "#D4AF37",
    git_deleted = "#808080",
    git_renamed = "#5FA8FF",
    git_copied = "#5FD7D7",
    git_untracked = "#A57C4C",
    git_unmerged = "#E0A84B",
    git_staged = "#5FB3A3",
  }

  local hl = vim.api.nvim_set_hl

  hl(0, "Normal", { fg = palette.fg, bg = palette.bg })
  hl(0, "NormalNC", { fg = palette.fg, bg = palette.bg })
  hl(0, "NormalFloat", { fg = palette.ui_fg, bg = palette.bg })
