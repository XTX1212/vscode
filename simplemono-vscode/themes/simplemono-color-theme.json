  hl(0, "Directory", { fg = palette.ui_fg, bg = palette.bg })

  hl(0, "@punctuation.bracket", { fg = palette.fg })
  hl(0, "MatchParen", { fg = palette.fg, bg = "NONE" })

  for i = 1, 9 do
    hl(0, "IndentBlanklineIndent" .. i, { fg = "NONE", bg = "NONE" })
  end
  hl(0, "IndentBlanklineContextChar", { fg = "NONE", bg = "NONE" })
  hl(0, "IndentBlanklineScope", { fg = "NONE", bg = "NONE" })
  hl(0, "IndentLine", { fg = "NONE", bg = "NONE" })
  hl(0, "IndentLineSpace", { fg = "NONE", bg = "NONE" })


