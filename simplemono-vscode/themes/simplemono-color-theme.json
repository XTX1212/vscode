  hl(0, "PreProc", { fg = palette.macro })
  hl(0, "Include", { fg = palette.macro })
  hl(0, "PreCondit", { fg = palette.macro })
  hl(0, "cDefine", { fg = palette.macro })
  hl(0, "cPreCondit", { fg = palette.macro })
  hl(0, "cPreProc", { fg = palette.macro })
  hl(0, "cInclude", { fg = palette.macro })
  hl(0, "cIncluded", { fg = palette.macro })
