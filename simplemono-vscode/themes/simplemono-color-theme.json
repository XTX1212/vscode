  hl(0, "SnacksDashboard", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksDashboardHeader", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksDashboardFooter", { fg = palette.ui_fg, bg = palette.bg })
