  hl(0, "SnacksPickerGitBranch", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksPickerGitBranchCurrent", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksPickerGitCommit", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksPickerGitAuthor", { fg = palette.ui_fg, bg = palette.bg })
  hl(0, "SnacksPickerGitDate", { fg = palette.ui_fg, bg = palette.bg })
