  hl(0, "LineNrBelow", { fg = palette.line_nr, bg = palette.bg })
  hl(0, "CursorLineNr", { fg = palette.keyword, bg = palette.bg, bold = true })
  hl(0, "CursorLine", { bg = "NONE" })
  hl(0, "NonText", { fg = palette.dim, bg = palette.bg })
  hl(0, "Whitespace", { fg = palette.dim, bg = palette.bg })

  hl(0, "Keyword", { fg = palette.keyword })
  hl(0, "Statement", { fg = palette.keyword })
